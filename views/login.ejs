<!DOCTYPE html>
<html>
<head>
	<title>GitHook - Log In</title>
	<meta charset="UTF-8">
<link rel="icon" type="image/png" href="/assets/img/logo.png"/>
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<script src="https://www.google.com/recaptcha/api.js" async defer></script>
	<style>
		body {
  font-family: Arial, sans-serif;
  background-color: #111;
  color: #fff;
}

h1 {
  text-align: center;
  color: #fff;
}

form {
  background-color: #292929;
  padding: 20px;
  border-radius: 10px;
  box-shadow: 0px 0px 10px rgba(255, 255, 255, 0.1);
  width: 300px;
  margin: 0 auto;
  text-align: center; /* Center form elements */
}

label {
  display: block;
  font-weight: bold;
  margin-bottom: 5px;
  color: #fff;
  text-align: left; /* Align label text to the left */
}

input[type="email"],
input[type="password"] {
  width: 100%;
  padding: 10px;
  border-radius: 5px;
  border: none;
  margin-bottom: 20px;
  background-color: #333;
  color: #fff;
  box-sizing: border-box;
}

.captcha-container {
  margin-bottom: 20px;
}

input[type="submit"] {
  background-color: #fff;
  color: #333;
  border-radius: 5px;
  border: none;
  padding: 10px;
  font-weight: bold;
  cursor: pointer;
  width: 100%; /* Set the width of the submit button to 100% */
  margin-top: 10px; /* Add a margin-top to separate the button from the input fields */
}

input[type="submit"]:hover {
  background-color: #333;
  color: #fff;
}

.g-recaptcha {
  display: inline-block;
  text-align: center;
}



	</style>
</head>
<body>
	<h1>Login</h1>
	<form method="POST">
		<label for="email">Email:</label>
		<input type="email" id="email" name="email" required>
		<label for="password">Password:</label>
		<input type="password" id="password" name="password" required>
		<div class="captcha-container">
			<div class="g-recaptcha" data-sitekey="<%= recaptchaKey %>" data-theme="dark"></div>
		</div>
		<input type="submit" value="Login">
	</form>
</body>
</html>
