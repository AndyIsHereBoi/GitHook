<!DOCTYPE html>
<html>
<head>
	<title>Forgot Password</title>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>

	<style>
		body {
			font-family: Arial, sans-serif;
			background-color: #111;
			color: #fff;
		}

		h1 {
			text-align: center;
			color: #fff;
		}

		form {
			background-color: #292929;
			padding: 20px;
			border-radius: 10px;
			box-shadow: 0px 0px 10px rgba(255, 255, 255, 0.1);
			width: 300px;
			margin: 0 auto;
			text-align: center;
		}

		label {
			display: block;
			font-weight: bold;
			margin-bottom: 5px;
			color: #fff;
			text-align: left;
		}

		input[type="email"] {
			width: 100%;
			padding: 10px;
			border-radius: 5px;
			border: none;
			margin-bottom: 20px;
			background-color: #333;
			color: #fff;
			box-sizing: border-box;
		}

		input[type="submit"] {
			background-color: #fff;
			color: #333;
			border-radius: 5px;
			border: none;
			padding: 10px;
			font-weight: bold;
			cursor: pointer;
			width: 100%;
			margin-top: 10px;
		}

		input[type="submit"]:hover {
			background-color: #333;
			color: #fff;
		}
	</style>
</head>
<body>
	<h1>Forgot Password</h1>
	<form method="POST">
		<label for="email">Email:</label>
		<input type="email" id="email" name="email" required>

		<div class="captcha-container"><!-- Add captcha-container div wrapper -->
			<div class="g-recaptcha" data-sitekey="<%= recaptchaKey %>" data-theme="dark"></div>
		</div>

		<input type="submit" value="Reset Password">
	</form>
</body>
</html>